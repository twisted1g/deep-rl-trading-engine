# Hyperliquid wallet (testnet или mainnet).
# Если оставить пустым — при первом старте контейнер сгенерирует кошелёк
# и сохранит ключ в state/wallet.key. Адрес попадёт в лог. Дальше нужно:
#   1) Открыть https://app.hyperliquid-testnet.xyz/ этим кошельком
#   2) Portfolio → Claim Mock USDC
#   3) docker compose restart engine
# Если уже есть кошелёк — впишите ключ ниже.
HL_WALLET_PRIVATE_KEY=
# Опционально: основной account address, если используется API Wallet sub-key.
# Иначе берётся адрес от приватного ключа выше.
HL_ACCOUNT_ADDRESS=

# Telegram bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
